rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /tasks_attachments/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.size < 50 * 1024 * 1024; // Max 50MB
    }
    match /users/{userId}/avatar {
      allow read: if true; // Public read for header, profile, reviews, leaderboard
      allow write: if request.auth != null && request.auth.uid == userId && request.resource.size < 5 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
