rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS ---
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Explicit check to see if request is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Role Lookup function
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'q2BisrMhIBdICRbrDPEp0Lr9iZu2' || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
        )
      );
    }

    function isNotBanned() {
      return isSignedIn() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned == false
      );
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // --- ENTITY SCHEMA VALIDATORS ---

    // User Validator
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 150 &&
             data.city is string && data.city.size() <= 100 &&
             (!('phone' in data) || data.phone == null || (data.phone is string && data.phone.size() <= 30)) &&
             (!('avatarId' in data) || data.avatarId == null || (data.avatarId is string && data.avatarId.size() <= 50)) &&
             (!('rating' in data) || data.rating == null || (data.rating is number)) &&
             (!('reviewsCount' in data) || data.reviewsCount == null || (data.reviewsCount is int)) &&
             (!('completedTasksCount' in data) || data.completedTasksCount == null || (data.completedTasksCount is int)) &&
             (!('acceptedTasksCount' in data) || data.acceptedTasksCount == null || (data.acceptedTasksCount is int)) &&
             data.isAdmin is bool &&
             data.isBanned is bool;
    }

    // Task Validator
    function isValidTask(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 500 &&
             data.description is string && data.description.size() <= 10000 &&
             data.category is string && data.category.matches('^(elderly|delivery|moving|education|technology|healthcare|ecology|other)$') &&
             data.priority is string && data.priority.matches('^(high|medium|low)$') &&
             data.deadline is string && data.deadline.size() <= 100 &&
             data.status is string && data.status.matches('^(new|in_progress|completed|pending_review|active|accepted|expired|blocked)$') &&
             data.city is string && data.city.size() <= 200 &&
             data.creatorId is string && data.creatorId.size() <= 128 &&
             data.creatorName is string && data.creatorName.size() <= 200 &&
             (!('creatorAvatar' in data) || data.creatorAvatar == null || (data.creatorAvatar is string && data.creatorAvatar.size() <= 100)) &&
             (!('volunteerId' in data) || data.volunteerId == null || (data.volunteerId is string && data.volunteerId.size() <= 128)) &&
             (!('volunteerName' in data) || data.volunteerName == null || (data.volunteerName is string && data.volunteerName.size() <= 200)) &&
             (!('volunteerAvatar' in data) || data.volunteerAvatar == null || (data.volunteerAvatar is string && data.volunteerAvatar.size() <= 100)) &&
             (!('attachmentUrl' in data) || data.attachmentUrl == null || (data.attachmentUrl is string && data.attachmentUrl.size() <= 2000)) &&
             (!('attachmentName' in data) || data.attachmentName == null || (data.attachmentName is string && data.attachmentName.size() <= 1000)) &&
             (!('attachmentSize' in data) || data.attachmentSize == null || (data.attachmentSize is number)) &&
             (!('ownerId' in data) || data.ownerId == null || (data.ownerId is string && data.ownerId.size() <= 128)) &&
             (!('ownerName' in data) || data.ownerName == null || (data.ownerName is string && data.ownerName.size() <= 200)) &&
             (!('ownerEmail' in data) || data.ownerEmail == null || (data.ownerEmail is string && data.ownerEmail.size() <= 200)) &&
             (!('ownerPhone' in data) || data.ownerPhone == null || (data.ownerPhone is string && data.ownerPhone.size() <= 100)) &&
             (!('address' in data) || data.address == null || (data.address is string && data.address.size() <= 1000)) &&
             (!('latitude' in data) || data.latitude == null || (data.latitude is number)) &&
             (!('longitude' in data) || data.longitude == null || (data.longitude is number)) &&
             (!('locationSource' in data) || data.locationSource == null || (data.locationSource is string && data.locationSource.size() <= 100)) &&
             (!('createdAt' in data) || data.createdAt == null || (data.createdAt is string && data.createdAt.size() <= 100)) &&
             (!('updatedAt' in data) || data.updatedAt == null || (data.updatedAt is string && data.updatedAt.size() <= 100));
    }

    // Review Validator
    function isValidReview(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.taskId is string && data.taskId.size() <= 128 &&
             data.reviewerId is string && data.reviewerId.size() <= 128 &&
             data.reviewerName is string && data.reviewerName.size() <= 100 &&
             (!('reviewerAvatar' in data) || data.reviewerAvatar == null || (data.reviewerAvatar is string && data.reviewerAvatar.size() <= 50)) &&
             data.targetUserId is string && data.targetUserId.size() <= 128 &&
             data.rating is int && data.rating >= 1 && data.rating <= 5 &&
             data.text is string && data.text.size() <= 1000 &&
             (!('createdAt' in data) || data.createdAt == null || (data.createdAt is string && data.createdAt.size() <= 50));
    }

    // Notification Validator
    function isValidNotification(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.title is string && data.title.size() <= 150 &&
             data.message is string && data.message.size() <= 500 &&
             (!('taskId' in data) || data.taskId == null || (data.taskId is string && data.taskId.size() <= 128)) &&
             data.type is string && data.type.matches('^(task_accepted|task_completed|new_review|system)$') &&
             data.isRead is bool &&
             (!('createdAt' in data) || data.createdAt == null || (data.createdAt is string && data.createdAt.size() <= 50));
    }

    // Report Validator
    function isValidReport(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.reporterId is string && data.reporterId.size() <= 128 &&
             data.reporterName is string && data.reporterName.size() <= 100 &&
             data.targetType is string && data.targetType.matches('^(user|task)$') &&
             data.targetId is string && data.targetId.size() <= 128 &&
             data.targetLabel is string && data.targetLabel.size() <= 200 &&
             data.reason is string && data.reason.size() <= 1000 &&
             data.status is string && data.status.matches('^(pending|resolved)$') &&
             (!('createdAt' in data) || data.createdAt == null || (data.createdAt is string && data.createdAt.size() <= 50));
    }

    // --- COLLECTION ROUTES ---

    // 1. Users Profiles Route
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) &&
                    (incoming().isAdmin == false || request.auth.token.email == 'sanjaresenalin@gmail.com' || request.auth.uid == 'q2BisrMhIBdICRbrDPEp0Lr9iZu2');
      allow update: if isSignedIn() && isValidUser(incoming()) && (
                    // Self update (block switching isAdmin/isBanned manually)
                    (request.auth.uid == userId && 
                     incoming().isAdmin == existing().isAdmin && 
                     incoming().isBanned == existing().isBanned) ||
                    // Rate user action (allows modifying rating and reviewsCount on completing/submitting reviews)
                    (incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'reviewsCount'])) ||
                    // Admin update
                    isAdmin()
                  );
      allow delete: if isAdmin();
    }

    // 2. Tasks Route
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if (isAdmin() || (isNotBanned() && isEmailVerified())) && 
                    isValidId(taskId) && isValidTask(incoming()) &&
                    incoming().creatorId == request.auth.uid && 
                    (incoming().status == 'new' || incoming().status == 'active');
      allow update: if (isAdmin() || (isNotBanned() && isEmailVerified())) && 
                    isValidId(taskId) && isValidTask(incoming()) && (
                    // Creator updating details (cannot modify status to completed directly from new/active)
                    (request.auth.uid == existing().creatorId && 
                     (existing().status == 'new' || existing().status == 'active') && 
                     (incoming().status == 'new' || incoming().status == 'active')) ||
                    // Volunteer accepting task (from active/new to accepted/in_progress)
                    ((existing().status == 'new' || existing().status == 'active') && 
                     (incoming().status == 'accepted' || incoming().status == 'in_progress') && 
                     incoming().volunteerId == request.auth.uid) ||
                    // Volunteer opting out from accepted task (reset to active/new)
                    ((existing().status == 'accepted' || existing().status == 'in_progress') && 
                     (incoming().status == 'active' || incoming().status == 'new') && 
                     existing().volunteerId == request.auth.uid && 
                     incoming().volunteerId == null) ||
                    // Creator confirming completion
                    (request.auth.uid == existing().creatorId && 
                     (existing().status == 'accepted' || existing().status == 'in_progress') && 
                     incoming().status == 'completed') ||
                    // Expiration / Auto-flag / status update
                    ((incoming().status == 'expired' || incoming().status == 'blocked' || incoming().status == 'pending_review') && 
                     incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
                  );
      allow delete: if isSignedIn() && isValidId(taskId) && (
                    (request.auth.uid == existing().creatorId && (existing().status == 'new' || existing().status == 'active')) || 
                    isAdmin()
                  );
    }

    // 3. Reviews Route
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if (isAdmin() || (isNotBanned() && isEmailVerified())) && 
                    isValidId(reviewId) && isValidReview(incoming()) &&
                    incoming().reviewerId == request.auth.uid && 
                    incoming().reviewerId != incoming().targetUserId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 4. Notifications Route
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && isValidId(notificationId) && 
                  (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && 
                  (existing().userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && isValidId(notificationId) && 
                     (existing().userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(notificationId) && isValidNotification(incoming());
      allow update: if isSignedIn() && isValidId(notificationId) && 
                    (existing().userId == request.auth.uid || isAdmin()) && 
                    isValidNotification(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
    }

    // 5. Reports Route
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if (isAdmin() || (isNotBanned() && isEmailVerified())) && 
                    isValidId(reportId) && isValidReport(incoming()) &&
                    incoming().reporterId == request.auth.uid && 
                    incoming().status == 'pending';
      allow update, delete: if isAdmin();
    }

    // 6. Participations Route
    match /participations/{pId} {
      allow read: if isSignedIn();
      allow create, update: if (isAdmin() || (isNotBanned() && isEmailVerified()));
      allow delete: if isAdmin();
    }
  }
}
